{
  "experiment": {
    "iterations": {
      "set": 20,
      "rep": 10
    },
    "omit_null_fields": true,
    "locations": {
      "config": {
        "dir": "config",
        "files": {
          "queries":     "queries.json",
          "texts":       "text.json",
          "prompts":     "prompts.json",
          "deployments": "deployments.json"
        }
      },
      "output": { "dir": "output" },
      "log":    { "dir": "log"    }
    },
    "timing": {
      "pause": {
        "run": {
          "set":    60,
          "prompt":   0,
          "rep":      5,
          "deployment": 0
        }
      }
    },
    "seed": {
      "shuffle": {
        "run": {
          "prompt": 99,
          "deployment": 20
        },
        "content": 42
      }
    },
    "parallel": {
      "max_concurrency": 6,
      "level": {
        "deployment": true,
        "rep":        true,
        "prompt":     true
      }
    }
  }
}
