@page "/"
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Results Viewer</PageTitle>

<aside class="side-bar @(_sidebarCollapsed ? "collapsed" : "")">
    <div class="side-bar-header">
        @if (!_sidebarCollapsed)
        {
            <span class="side-title">Results Viewer</span>
        }
        <button class="side-toggle" title="@(_sidebarCollapsed ? "Expand" : "Collapse")"
                @onclick="() => _sidebarCollapsed = !_sidebarCollapsed">
            @(_sidebarCollapsed ? "›" : "‹")
        </button>
    </div>
    <nav class="side-nav">
        <button class="side-btn" @onclick="GoHome">Home</button>
        <button class="side-btn" @onclick="ClearData">Clear</button>
        <label  class="side-btn" for="file-open">Open</label>
        <InputFile id="file-open" style="display:none" OnChange="@LoadFile" accept=".json" />
        <details class="side-dropdown">
            <summary class="side-btn">Examples</summary>
            <ul class="side-dropdown-menu">
                <li><a href="?example=v0.9.0">v0.9.0</a></li>
            </ul>
        </details>
        @if (_loadedFromFile)
        {
            <span class="loaded-badge sidebar-badge">local file loaded</span>
        }
        <a class="side-btn side-docs-link" href="/" target="_top">Documentation</a>
    </nav>
</aside>
<div class="content-area">

@if (_loading)
{
    <p class="status-msg">Loading&hellip;</p>
}
else if (_error != null && _records == null)
{
    <div class="error-banner">@_error</div>
    <p class="status-msg hint">Select an example from the Examples menu, or use the file picker below.</p>
}
else if (_records != null)
{
    @if (_error != null)
    {
        <div class="error-banner warn">@_error</div>
    }

    <section class="run-summary">
        <h2>Run</h2>
        <ul class="run-stats">
            <li><b>@_runLabel</b></li>
            <li><b>@_deployments.Count</b> deployment@(_deployments.Count != 1 ? "s" : "")</li>
            <li><b>@_records.Count</b> records total</li>
            <li><b>@_successCount</b> OK &middot; <b>@_errorCount</b> error@(_errorCount != 1 ? "s" : "")</li>
        </ul>
        @if (_deployments.Count > 0)
        {
            <div class="deployment-chips">
                @foreach (var d in _deployments)
                {
                    <span class="chip">@d</span>
                }
            </div>
        }
    </section>

    <div class="tabs">
        <button class="tab-btn @(_activeTab == "summary"    ? "active" : "")"
                @onclick='() => _activeTab = "summary"'>Summary</button>
        <button class="tab-btn @(_activeTab == "deployment" ? "active" : "")"
                @onclick='() => _activeTab = "deployment"'>By Deployment</button>
        <button class="tab-btn @(_activeTab == "identity"   ? "active" : "")"
                @onclick='() => _activeTab = "identity"'>Identity Groups</button>
        <button class="tab-btn @(_activeTab == "charts"     ? "active" : "")"
                @onclick='() => _activeTab = "charts"'>Charts</button>
        <button class="tab-btn @(_activeTab == "overview"   ? "active" : "")"
                @onclick='() => _activeTab = "overview"'>Overview</button>
    </div>

    @if (_activeTab == "summary")
    {
    <section>
        <h2>Summary &mdash; Counts</h2>
        <div style="overflow-x: auto">
        <table>
            <thead>
                <tr>
                    <th>Text</th>
                    <th>Query</th>
                    <th>Deployment</th>
                    <th class="num">n</th>
                    <th class="num">n_ok</th>
                    <th class="num">n_err</th>
                    <th class="num">exact</th>
                    <th class="num">coverage</th>
                    <th class="num">halluc</th>
                    <th class="num">li1</th>
                    <th class="num">pos_score</th>
                    <th class="num">min_moves</th>
                    <th class="num">title_hit</th>
                    <th class="num">tb_hit</th>
                    <th class="num">lp_mean</th>
                    <th class="num">lp_med</th>
                    <th class="num">tlp_mean</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _summaryRows)
                {
                    <tr>
                        <td class="mono small">@r.TextLabel</td>
                        <td class="mono small">@r.QueryLabel</td>
                        <td class="mono small">@r.Deployment</td>
                        <td class="num">@r.N</td>
                        <td class="num">@r.NOk</td>
                        <td class="num @(r.NErr > 0 ? "cell-error" : "")">@r.NErr</td>
                        <td class="num">@r.Exact</td>
                        <td class="num">@r.Cov</td>
                        <td class="num">@r.Halluc</td>
                        <td class="num">@r.Li1Cnt</td>
                        <td class="num">@r.PosScore</td>
                        <td class="num">@r.MinMoves</td>
                        <td class="num">@r.TitleCnt</td>
                        <td class="num">@r.TbCnt</td>
                        <td class="num">@r.LpMean</td>
                        <td class="num">@r.LpMed</td>
                        <td class="num">@r.TlpMean</td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </section>

    <section>
        <h2>Summary &mdash; Percentages</h2>
        <div style="overflow-x: auto">
        <table>
            <thead>
                <tr>
                    <th>Text</th>
                    <th>Query</th>
                    <th>Deployment</th>
                    <th class="num">n</th>
                    <th class="num">n_ok</th>
                    <th class="num">n_err</th>
                    <th class="num">n_ok%</th>
                    <th class="num">n_err%</th>
                    <th class="num">perf%</th>
                    <th class="num">cov%</th>
                    <th class="num">li1%</th>
                    <th class="num">ord%</th>
                    <th class="num">title%</th>
                    <th class="num">tb%</th>
                    <th class="num">lp_geo%</th>
                    <th class="num">lp_ari%</th>
                    <th class="num">lp_med_geo%</th>
                    <th class="num">lp_med_ari%</th>
                    <th class="num">tlp_geo%</th>
                    <th class="num">tlp_ari%</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _summaryRows)
                {
                    <tr>
                        <td class="mono small">@r.TextLabel</td>
                        <td class="mono small">@r.QueryLabel</td>
                        <td class="mono small">@r.Deployment</td>
                        <td class="num">@r.N</td>
                        <td class="num">@r.NOk</td>
                        <td class="num @(r.NErr > 0 ? "cell-error" : "")">@r.NErr</td>
                        <td class="num">@r.NOkPct</td>
                        <td class="num">@r.NErrPct</td>
                        <td class="num">@r.PerfPct</td>
                        <td class="num">@r.CovPct</td>
                        <td class="num">@r.Li1Pct</td>
                        <td class="num">@r.OrdPct</td>
                        <td class="num">@r.TitlePct</td>
                        <td class="num">@r.TbPct</td>
                        <td class="num">@r.LpmGeo</td>
                        <td class="num">@r.LpmAri</td>
                        <td class="num">@r.LpmMedGeo</td>
                        <td class="num">@r.LpmMedAri</td>
                        <td class="num">@r.TlpGeo</td>
                        <td class="num">@r.TlpAri</td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </section>
    }
    else if (_activeTab == "deployment")
    {
    <section>
        <h2>By Deployment &mdash; Counts</h2>
        <table>
            <thead>
                <tr>
                    <th>Deployment</th>
                    <th class="num">Calls</th>
                    <th class="num">OK</th>
                    <th class="num">Perfect</th>
                    <th class="num">Errors</th>
                    <th class="num">Avg ms</th>
                    <th class="num">Avg tokens</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in _deploymentStats)
                {
                    <tr>
                        <td class="mono">@d.Deployment</td>
                        <td class="num">@d.Total</td>
                        <td class="num">@d.Success</td>
                        <td class="num">@d.Perfect</td>
                        <td class="num @(d.Errors > 0 ? "cell-error" : "")">@d.Errors</td>
                        <td class="num">@d.AvgMs</td>
                        <td class="num">@d.AvgTokens</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    <section>
        <h2>By Deployment &mdash; Percentages</h2>
        <table>
            <thead>
                <tr>
                    <th>Deployment</th>
                    <th class="num">OK%</th>
                    <th class="num">Perfect%</th>
                    <th class="num">Error%</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in _deploymentStats)
                {
                    string okPct      = d.Total   > 0 ? (d.Success * 100.0 / d.Total).ToString("F1")   + "%" : "—";
                    string perfectPct = d.Success > 0 ? (d.Perfect * 100.0 / d.Success).ToString("F1") + "%" : "—";
                    string errorPct   = d.Total   > 0 ? (d.Errors  * 100.0 / d.Total).ToString("F1")   + "%" : "—";
                    <tr>
                        <td class="mono">@d.Deployment</td>
                        <td class="num">@okPct</td>
                        <td class="num">@perfectPct</td>
                        <td class="num @(d.Errors > 0 ? "cell-error" : "")">@errorPct</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
    }
    else if (_activeTab == "identity")
    {
    <section>
        <h2>Identity Groups</h2>
        <p class="subtitle">
            Records grouped by content SHA-256 — identical entries share the same LLM output.
            @_totalGroups group@(_totalGroups != 1 ? "s" : "") total
            (@_singletonCount singleton@(_singletonCount != 1 ? "s" : "") hidden).
            Showing @_identityGroups.Count group@(_identityGroups.Count != 1 ? "s" : "") with count &ge; 2.
            <label class="toggle-label">
                <input type="checkbox" @bind="_showSingletons" />
                show all
            </label>
        </p>
        <table>
            <thead>
                <tr>
                    <th>Hash</th>
                    <th class="num">Count</th>
                    <th>Deployments</th>
                    <th>Text &middot; Query</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var g in _showSingletons ? _allIdentityGroups : _identityGroups)
                {
                    <tr class="@(g.Deployments.Count > 1 ? "row-shared" : "")">
                        <td class="mono hash">@g.Hash</td>
                        <td class="num">@g.Count</td>
                        <td class="mono small">@string.Join(", ", g.Deployments)</td>
                        <td class="small">@g.Label</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
    }
    else if (_activeTab == "charts")
    {
    <div class="chart-grid">
        <figure class="chart-figure">
            <ApexChart TItem="BarPoint" Options="@_fig1Opts" Title="Fig 1 — HTTP Reliability (mean n_ok%)">
                <ApexPointSeries TItem="BarPoint"
                    Items="@GetFig1Data()"
                    SeriesType="SeriesType.Bar"
                    XValue="@(e => e.Label)"
                    YValue="@(e => (decimal)e.Value)" />
            </ApexChart>
            <figcaption>Mean HTTP success rate per deployment across all text–query combinations.</figcaption>
        </figure>
        <figure class="chart-figure">
            <ApexChart TItem="BarPoint" Options="@_fig2Opts" Title="Fig 2 — Recall Coverage (title→TOC)">
                <ApexPointSeries TItem="BarPoint"
                    Items="@GetBarData("toronto-notes-2022","title_to_toc",r=>r.CovPct)"
                    Name="TN 2022"
                    SeriesType="SeriesType.Bar"
                    XValue="@(e => e.Label)"
                    YValue="@(e => (decimal)e.Value)" />
                <ApexPointSeries TItem="BarPoint"
                    Items="@GetBarData("bates-guide-13e","title_to_toc",r=>r.CovPct)"
                    Name="Bates 13e"
                    SeriesType="SeriesType.Bar"
                    XValue="@(e => e.Label)"
                    YValue="@(e => (decimal)e.Value)" />
            </ApexChart>
            <figcaption>Mean coverage % when asked to list the table of contents from the title alone.</figcaption>
        </figure>
        <figure class="chart-figure">
            <ApexChart TItem="BarPoint" Options="@_fig4aOpts" Title="Fig 4a — Ordering: Perfect (shuffled→order)">
                <ApexPointSeries TItem="BarPoint"
                    Items="@GetBarData("toronto-notes-2022","shuffled_toc_to_order",r=>r.PerfPct)"
                    Name="TN 2022"
                    SeriesType="SeriesType.Bar"
                    XValue="@(e => e.Label)"
                    YValue="@(e => (decimal)e.Value)" />
                <ApexPointSeries TItem="BarPoint"
                    Items="@GetBarData("bates-guide-13e","shuffled_toc_to_order_us",r=>r.PerfPct)"
                    Name="Bates 13e"
                    SeriesType="SeriesType.Bar"
                    XValue="@(e => e.Label)"
                    YValue="@(e => (decimal)e.Value)" />
            </ApexChart>
            <figcaption>% of runs with perfect pairwise ordering when given a shuffled TOC.</figcaption>
        </figure>
        <figure class="chart-figure">
            <ApexChart TItem="BarPoint" Options="@_fig4bOpts" Title="Fig 4b — Ordering: Pairwise Accuracy">
                <ApexPointSeries TItem="BarPoint"
                    Items="@GetBarData("toronto-notes-2022","shuffled_toc_to_order",r=>r.OrderPctMean)"
                    Name="TN 2022"
                    SeriesType="SeriesType.Bar"
                    XValue="@(e => e.Label)"
                    YValue="@(e => (decimal)e.Value)" />
                <ApexPointSeries TItem="BarPoint"
                    Items="@GetBarData("bates-guide-13e","shuffled_toc_to_order_us",r=>r.OrderPctMean)"
                    Name="Bates 13e"
                    SeriesType="SeriesType.Bar"
                    XValue="@(e => e.Label)"
                    YValue="@(e => (decimal)e.Value)" />
            </ApexChart>
            <figcaption>Mean pairwise order accuracy % across runs with a shuffled TOC.</figcaption>
        </figure>
    </div>
    }
    else if (_activeTab == "overview")
    {
    <section>
        <h2>Fig 3 — Source Identification</h2>
        <figure class="chart-figure">
            <ApexChart TItem="HeatCell" Options="@_heatOpts" Title="Source ID (title hit %)">
                @for (int di = 0; di < DeployOrder.Length; di++)
                {
                    <ApexPointSeries TItem="HeatCell"
                        Items="@GetFig3Cells(DeployOrder[di])"
                        Name="@DeployLabels[di]"
                        SeriesType="SeriesType.Heatmap"
                        XValue="@(e => e.ColLabel)"
                        YValue="@(e => (decimal)e.Value)" />
                }
            </ApexChart>
            <figcaption>Title / textbook hit % when shown the table of contents with the title withheld.</figcaption>
        </figure>
    </section>
    <section>
        <h2>Figs 5a / 5b / 5c — Overview Heatmaps</h2>
        <div class="heatmap-row">
            <figure class="chart-figure">
                <ApexChart TItem="HeatCell" Options="@_heatOpts" Title="Fig 5a — Toronto Notes 2022">
                    @for (int di = 0; di < DeployOrder.Length; di++)
                    {
                        <ApexPointSeries TItem="HeatCell"
                            Items="@GetFig5aCells(DeployOrder[di])"
                            Name="@DeployLabels[di]"
                            SeriesType="SeriesType.Heatmap"
                            XValue="@(e => e.ColLabel)"
                            YValue="@(e => (decimal)e.Value)" />
                    }
                </ApexChart>
                <figcaption>recall = cov%; rcl* = perfect%; id-ord/shuf = title hit%; ord-acc = pairwise%; ord* = perfect%</figcaption>
            </figure>
            <figure class="chart-figure">
                <ApexChart TItem="HeatCell" Options="@_heatOpts" Title="Fig 5b — Bates 13e">
                    @for (int di = 0; di < DeployOrder.Length; di++)
                    {
                        <ApexPointSeries TItem="HeatCell"
                            Items="@GetFig5bCells(DeployOrder[di])"
                            Name="@DeployLabels[di]"
                            SeriesType="SeriesType.Heatmap"
                            XValue="@(e => e.ColLabel)"
                            YValue="@(e => (decimal)e.Value)" />
                    }
                </ApexChart>
                <figcaption>Same column structure as 5a but for Bates Guide to Physical Examination 13e.</figcaption>
            </figure>
            <figure class="chart-figure">
                <ApexChart TItem="HeatCell" Options="@_heatOpts" Title="Fig 5c — Bates Ch. 11">
                    @for (int di = 0; di < DeployOrder.Length; di++)
                    {
                        <ApexPointSeries TItem="HeatCell"
                            Items="@GetFig5cCells(DeployOrder[di])"
                            Name="@DeployLabels[di]"
                            SeriesType="SeriesType.Heatmap"
                            XValue="@(e => e.ColLabel)"
                            YValue="@(e => (decimal)e.Value)" />
                    }
                </ApexChart>
                <figcaption>id-ord/shuf = textbook hit%; others match 5a/5b column definitions.</figcaption>
            </figure>
        </div>
    </section>
    }
}
else
{
    <div class="welcome-msg">
        <p>Select an example from the <strong>Examples</strong> menu in the sidebar,
        or load a local <code>manifest.json</code> with <strong>Open</strong>.</p>
    </div>
}

</div>

@code {
    private List<RunRecord>? _records;
    private string?          _error;
    private bool             _loading          = false;
    private bool             _loadedFromFile;
    private string?          _loadedExample;
    private bool             _sidebarCollapsed = false;
    private string           _runLabel      = "";
    private List<string>     _deployments   = new();
    private int              _successCount;
    private int              _errorCount;

    private List<SummaryRow>     _summaryRows        = new();
    private List<DeploymentStat> _deploymentStats    = new();
    private string               _activeTab          = "summary";
    private List<IdentityGroup>  _identityGroups     = new();
    private List<IdentityGroup>  _allIdentityGroups  = new();
    private int                  _totalGroups;
    private int                  _singletonCount;
    private bool                 _showSingletons;

    private static readonly JsonSerializerOptions _jsonOpts =
        new() { PropertyNameCaseInsensitive = true };

    private static readonly string[] DeployOrder =
        ["deepseek-model","deepseek-agent","deepseek-native",
         "deepseek-native-t1","gpt-oss-model","gpt-oss-agent"];
    private static readonly string[] DeployLabels =
        ["ds-model","ds-agent","ds-native","ds-native-t1","gpt-model","gpt-agent"];

    private static readonly List<PlotOptionsHeatmapColorScaleRange> RdYlGn =
    [
        new() { From = 0,  To = 25,  Color = "#D7191C" },
        new() { From = 25, To = 50,  Color = "#FDAE61" },
        new() { From = 50, To = 75,  Color = "#FFFFBF" },
        new() { From = 75, To = 101, Color = "#1A9641" },
    ];

    private Dictionary<(string Text, string Query, string Deploy), ChartRow> _chartLookup = new();

    private record DeploymentStat(
        string Deployment, int Total, int Success, int Perfect, int Errors,
        long AvgMs, string AvgTokens);

    private record SummaryRow(
        string TextLabel, string QueryLabel, string Deployment,
        int N, int NOk, int NErr,
        // counts
        string Exact, string Cov, string Halluc, string Li1Cnt,
        string PosScore, string MinMoves, string TitleCnt, string TbCnt,
        string LpMean, string LpMed, string TlpMean,
        // percentages
        string NOkPct, string NErrPct, string PerfPct,
        string CovPct, string Li1Pct, string OrdPct, string TitlePct, string TbPct,
        string LpmGeo, string LpmAri, string LpmMedGeo, string LpmMedAri,
        string TlpGeo, string TlpAri);

    private record IdentityGroup(
        string Hash, int Count, List<string> Deployments, string Label);

    private record BarPoint(string Label, double Value);
    private record HeatCell(string ColLabel, double Value);
    private record ChartRow(
        double NOkPct, double CovPct, double PerfPct,
        double TitleHitPct, double TextbookHitPct, double OrderPctMean);

    [SupplyParameterFromQuery(Name = "example")]
    public string? ExampleVersion { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (ExampleVersion is { Length: > 0 } version && version != _loadedExample)
        {
            _loadedExample = version;
            await LoadExample(version);
        }
    }

    private async Task LoadExample(string version)
    {
        _loading        = true;
        _error          = null;
        _loadedFromFile = false;
        StateHasChanged();
        try
        {
            _records = await Http.GetFromJsonAsync<List<RunRecord>>(
                $"data/{version}/manifest.json", _jsonOpts);
            if (_records is { Count: > 0 }) ProcessRecords(_records);
            else { _error = $"No records found in example {version}."; _records = null; }
        }
        catch (Exception ex)
        {
            _error   = $"Could not load example {version}: {ex.Message}";
            _records = null;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadFile(InputFileChangeEventArgs e)
    {
        _loading        = true;
        _error          = null;
        _loadedFromFile = false;
        StateHasChanged();
        try
        {
            await using var stream = e.File.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            var loaded = await JsonSerializer.DeserializeAsync<List<RunRecord>>(stream, _jsonOpts);
            if (loaded is null || loaded.Count == 0)
            {
                _error = "File deserialized to an empty list — is this a manifest.json from the harness?";
            }
            else
            {
                _records        = loaded;
                _loadedFromFile = true;
                ProcessRecords(_records);
            }
        }
        catch (Exception ex)
        {
            _error = $"Could not read file: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void GoHome()
    {
        var url = _loadedExample is { Length: > 0 }
            ? $"{Navigation.BaseUri}?example={_loadedExample}"
            : Navigation.BaseUri;
        Navigation.NavigateTo(url);
    }

    private double Pct(string text, string query, string deploy, Func<ChartRow, double> f)
        => _chartLookup.TryGetValue((text, query, deploy), out var r) ? f(r) : 0.0;

    // ── Chart options (instantiated once, referenced from markup) ──

    private readonly ApexChartOptions<BarPoint> _fig1Opts = new()
    {
        Chart       = new Chart { Height = 280 },
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { Horizontal = true, Distributed = true } },
        Colors      = DeployOrder.Select(d => d == "deepseek-agent" ? "#CC4444" : "#6699CC").ToList(),
        Legend      = new Legend { Show = false },
        DataLabels  = new DataLabels { Enabled = true },
    };

    private readonly ApexChartOptions<BarPoint> _fig2Opts = new()
    {
        Chart  = new Chart { Height = 300 },
        Colors = ["#4878CF", "#E8A838"],
    };

    private readonly ApexChartOptions<BarPoint> _fig4aOpts = new()
    {
        Chart  = new Chart { Height = 300 },
        Colors = ["#4878CF", "#E8A838"],
    };

    private readonly ApexChartOptions<BarPoint> _fig4bOpts = new()
    {
        Chart  = new Chart { Height = 300 },
        Colors = ["#4878CF", "#E8A838"],
    };

    private readonly ApexChartOptions<HeatCell> _heatOpts = new()
    {
        Chart      = new Chart { Height = 340 },
        PlotOptions = new PlotOptions
        {
            Heatmap = new PlotOptionsHeatmap
            {
                ColorScale = new PlotOptionsHeatmapColorScale { Ranges = RdYlGn }
            }
        },
        DataLabels = new DataLabels { Enabled = true },
    };

    // ── Chart data helpers ──

    private List<BarPoint> GetFig1Data() =>
        DeployOrder.Select((d, i) =>
        {
            var vals = _chartLookup.Where(kv => kv.Key.Deploy == d)
                                    .Select(kv => kv.Value.NOkPct).ToList();
            return new BarPoint(DeployLabels[i], vals.Count > 0 ? vals.Average() : 0);
        }).ToList();

    private List<BarPoint> GetBarData(string text, string query, Func<ChartRow, double> metric) =>
        DeployLabels.Zip(DeployOrder, (lbl, dep) => new BarPoint(lbl, Pct(text, query, dep, metric))).ToList();

    private List<HeatCell> GetFig3Cells(string deploy) =>
    [
        new("TN 2022",     Pct("toronto-notes-2022",   "toc_to_title",          deploy, r => r.TitleHitPct)),
        new("Bates 13e",   Pct("bates-guide-13e",      "toc_to_title_us",       deploy, r => r.TitleHitPct)),
