@page "/"
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Results Viewer</PageTitle>

<div class="action-bar">
    <button class="action-btn" @onclick="ClearData">Clear</button>
    <label class="action-btn" for="file-open">Open</label>
    <InputFile id="file-open" style="display:none" OnChange="@LoadFile" accept=".json" />
    <details class="action-dropdown">
        <summary class="action-btn">Examples</summary>
        <ul class="action-dropdown-menu">
            <li><a href="?example=v0.9.0">v0.9.0</a></li>
        </ul>
    </details>
    @if (_loadedFromFile)
    {
        <span class="loaded-badge">local file loaded</span>
    }
</div>

@if (_loading)
{
    <p class="status-msg">Loading&hellip;</p>
}
else if (_error != null && _records == null)
{
    <div class="error-banner">@_error</div>
    <p class="status-msg hint">Select an example from the Examples menu, or use the file picker below.</p>
}
else if (_records != null)
{
    @if (_error != null)
    {
        <div class="error-banner warn">@_error</div>
    }

    <section class="run-summary">
        <h2>Run</h2>
        <ul class="run-stats">
            <li><b>@_runLabel</b></li>
            <li><b>@_deployments.Count</b> deployment@(_deployments.Count != 1 ? "s" : "")</li>
            <li><b>@_records.Count</b> records total</li>
            <li><b>@_successCount</b> OK &middot; <b>@_errorCount</b> error@(_errorCount != 1 ? "s" : "")</li>
        </ul>
        @if (_deployments.Count > 0)
        {
            <div class="deployment-chips">
                @foreach (var d in _deployments)
                {
                    <span class="chip">@d</span>
                }
            </div>
        }
    </section>

    <div class="tabs">
        <button class="tab-btn @(_activeTab == "summary"    ? "active" : "")"
                @onclick='() => _activeTab = "summary"'>Summary</button>
        <button class="tab-btn @(_activeTab == "deployment" ? "active" : "")"
                @onclick='() => _activeTab = "deployment"'>By Deployment</button>
    </div>

    @if (_activeTab == "summary")
    {
    <section>
        <h2>Summary &mdash; Counts</h2>
        <div style="overflow-x: auto">
        <table>
            <thead>
                <tr>
                    <th>Text</th>
                    <th>Query</th>
                    <th>Deployment</th>
                    <th class="num">n</th>
                    <th class="num">n_ok</th>
                    <th class="num">n_err</th>
                    <th class="num">exact</th>
                    <th class="num">coverage</th>
                    <th class="num">halluc</th>
                    <th class="num">li1</th>
                    <th class="num">pos_score</th>
                    <th class="num">min_moves</th>
                    <th class="num">title_hit</th>
                    <th class="num">tb_hit</th>
                    <th class="num">lp_mean</th>
                    <th class="num">lp_med</th>
                    <th class="num">tlp_mean</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _summaryRows)
                {
                    <tr>
                        <td class="mono small">@r.TextLabel</td>
                        <td class="mono small">@r.QueryLabel</td>
                        <td class="mono small">@r.Deployment</td>
                        <td class="num">@r.N</td>
                        <td class="num">@r.NOk</td>
                        <td class="num @(r.NErr > 0 ? "cell-error" : "")">@r.NErr</td>
                        <td class="num">@r.Exact</td>
                        <td class="num">@r.Cov</td>
                        <td class="num">@r.Halluc</td>
                        <td class="num">@r.Li1Cnt</td>
                        <td class="num">@r.PosScore</td>
                        <td class="num">@r.MinMoves</td>
                        <td class="num">@r.TitleCnt</td>
                        <td class="num">@r.TbCnt</td>
                        <td class="num">@r.LpMean</td>
                        <td class="num">@r.LpMed</td>
                        <td class="num">@r.TlpMean</td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </section>

    <section>
        <h2>Summary &mdash; Percentages</h2>
        <div style="overflow-x: auto">
        <table>
            <thead>
                <tr>
                    <th>Text</th>
                    <th>Query</th>
                    <th>Deployment</th>
                    <th class="num">n</th>
                    <th class="num">n_ok</th>
                    <th class="num">n_err</th>
                    <th class="num">n_ok%</th>
                    <th class="num">n_err%</th>
                    <th class="num">perf%</th>
                    <th class="num">cov%</th>
                    <th class="num">li1%</th>
                    <th class="num">ord%</th>
                    <th class="num">title%</th>
                    <th class="num">tb%</th>
                    <th class="num">lp_geo%</th>
                    <th class="num">lp_ari%</th>
                    <th class="num">lp_med_geo%</th>
                    <th class="num">lp_med_ari%</th>
                    <th class="num">tlp_geo%</th>
                    <th class="num">tlp_ari%</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _summaryRows)
                {
                    <tr>
                        <td class="mono small">@r.TextLabel</td>
                        <td class="mono small">@r.QueryLabel</td>
                        <td class="mono small">@r.Deployment</td>
                        <td class="num">@r.N</td>
                        <td class="num">@r.NOk</td>
                        <td class="num @(r.NErr > 0 ? "cell-error" : "")">@r.NErr</td>
                        <td class="num">@r.NOkPct</td>
                        <td class="num">@r.NErrPct</td>
                        <td class="num">@r.PerfPct</td>
                        <td class="num">@r.CovPct</td>
                        <td class="num">@r.Li1Pct</td>
                        <td class="num">@r.OrdPct</td>
                        <td class="num">@r.TitlePct</td>
                        <td class="num">@r.TbPct</td>
                        <td class="num">@r.LpmGeo</td>
                        <td class="num">@r.LpmAri</td>
                        <td class="num">@r.LpmMedGeo</td>
                        <td class="num">@r.LpmMedAri</td>
                        <td class="num">@r.TlpGeo</td>
                        <td class="num">@r.TlpAri</td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </section>
    }
    else
    {
    <section>
        <h2>By Deployment &mdash; Counts</h2>
        <table>
            <thead>
                <tr>
                    <th>Deployment</th>
                    <th class="num">Calls</th>
                    <th class="num">OK</th>
                    <th class="num">Perfect</th>
                    <th class="num">Errors</th>
                    <th class="num">Avg ms</th>
                    <th class="num">Avg tokens</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in _deploymentStats)
                {
                    <tr>
                        <td class="mono">@d.Deployment</td>
                        <td class="num">@d.Total</td>
                        <td class="num">@d.Success</td>
                        <td class="num">@d.Perfect</td>
                        <td class="num @(d.Errors > 0 ? "cell-error" : "")">@d.Errors</td>
                        <td class="num">@d.AvgMs</td>
                        <td class="num">@d.AvgTokens</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    <section>
        <h2>By Deployment &mdash; Percentages</h2>
        <table>
            <thead>
                <tr>
                    <th>Deployment</th>
                    <th class="num">OK%</th>
                    <th class="num">Perfect%</th>
                    <th class="num">Error%</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in _deploymentStats)
                {
                    string okPct      = d.Total   > 0 ? (d.Success * 100.0 / d.Total).ToString("F1")   + "%" : "—";
                    string perfectPct = d.Success > 0 ? (d.Perfect * 100.0 / d.Success).ToString("F1") + "%" : "—";
                    string errorPct   = d.Total   > 0 ? (d.Errors  * 100.0 / d.Total).ToString("F1")   + "%" : "—";
                    <tr>
                        <td class="mono">@d.Deployment</td>
                        <td class="num">@okPct</td>
                        <td class="num">@perfectPct</td>
                        <td class="num @(d.Errors > 0 ? "cell-error" : "")">@errorPct</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
    }

    <section>
        <h2>Identity Groups</h2>
        <p class="subtitle">
            Records grouped by content SHA-256 — identical entries share the same LLM output.
            @_totalGroups group@(_totalGroups != 1 ? "s" : "") total
            (@_singletonCount singleton@(_singletonCount != 1 ? "s" : "") hidden).
            Showing @_identityGroups.Count group@(_identityGroups.Count != 1 ? "s" : "") with count &ge; 2.
            <label class="toggle-label">
                <input type="checkbox" @bind="_showSingletons" />
                show all
            </label>
        </p>
        <table>
            <thead>
                <tr>
                    <th>Hash</th>
                    <th class="num">Count</th>
                    <th>Deployments</th>
                    <th>Text &middot; Query</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var g in _showSingletons ? _allIdentityGroups : _identityGroups)
                {
                    <tr class="@(g.Deployments.Count > 1 ? "row-shared" : "")">
                        <td class="mono hash">@g.Hash</td>
                        <td class="num">@g.Count</td>
                        <td class="mono small">@string.Join(", ", g.Deployments)</td>
                        <td class="small">@g.Label</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}
else
{
    <div class="welcome-msg">
        <p>Select an example from the <strong>Examples</strong> menu above,
        or load a local <code>manifest.json</code> with the file picker below.</p>
    </div>
}

@code {
    private List<RunRecord>? _records;
    private string?          _error;
    private bool             _loading       = false;
    private bool             _loadedFromFile;
    private string?          _loadedExample;
    private string           _runLabel      = "";
    private List<string>     _deployments   = new();
    private int              _successCount;
    private int              _errorCount;

    private List<SummaryRow>     _summaryRows        = new();
    private List<DeploymentStat> _deploymentStats    = new();
    private string               _activeTab          = "summary";
    private List<IdentityGroup>  _identityGroups     = new();
    private List<IdentityGroup>  _allIdentityGroups  = new();
    private int                  _totalGroups;
    private int                  _singletonCount;
    private bool                 _showSingletons;

    private static readonly JsonSerializerOptions _jsonOpts =
        new() { PropertyNameCaseInsensitive = true };

    private record DeploymentStat(
        string Deployment, int Total, int Success, int Perfect, int Errors,
        long AvgMs, string AvgTokens);

    private record SummaryRow(
        string TextLabel, string QueryLabel, string Deployment,
        int N, int NOk, int NErr,
        // counts
        string Exact, string Cov, string Halluc, string Li1Cnt,
        string PosScore, string MinMoves, string TitleCnt, string TbCnt,
        string LpMean, string LpMed, string TlpMean,
        // percentages
        string NOkPct, string NErrPct, string PerfPct,
        string CovPct, string Li1Pct, string OrdPct, string TitlePct, string TbPct,
        string LpmGeo, string LpmAri, string LpmMedGeo, string LpmMedAri,
        string TlpGeo, string TlpAri);

    private record IdentityGroup(
        string Hash, int Count, List<string> Deployments, string Label);

    [SupplyParameterFromQuery(Name = "example")]
    public string? ExampleVersion { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (ExampleVersion is { Length: > 0 } version && version != _loadedExample)
        {
            _loadedExample = version;
            await LoadExample(version);
        }
    }

    private async Task LoadExample(string version)
    {
        _loading        = true;
        _error          = null;
        _loadedFromFile = false;
        StateHasChanged();
        try
        {
            _records = await Http.GetFromJsonAsync<List<RunRecord>>(
                $"data/{version}/manifest.json", _jsonOpts);
            if (_records is { Count: > 0 }) ProcessRecords(_records);
            else { _error = $"No records found in example {version}."; _records = null; }
        }
        catch (Exception ex)
        {
            _error   = $"Could not load example {version}: {ex.Message}";
            _records = null;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadFile(InputFileChangeEventArgs e)
    {
        _loading        = true;
        _error          = null;
        _loadedFromFile = false;
        StateHasChanged();
        try
        {
            await using var stream = e.File.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            var loaded = await JsonSerializer.DeserializeAsync<List<RunRecord>>(stream, _jsonOpts);
            if (loaded is null || loaded.Count == 0)
            {
                _error = "File deserialized to an empty list — is this a manifest.json from the harness?";
            }
            else
            {
                _records        = loaded;
                _loadedFromFile = true;
                ProcessRecords(_records);
            }
        }
        catch (Exception ex)
        {
            _error = $"Could not read file: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void ClearData()
    {
        _records          = null;
        _error            = null;
        _loading          = false;
        _loadedFromFile   = false;
        _loadedExample    = null;
        _runLabel         = "";
        _deployments      = new();
        _successCount     = 0;
        _errorCount       = 0;
        _summaryRows      = new();
        _deploymentStats  = new();
        _identityGroups   = new();
        _allIdentityGroups = new();
        _totalGroups      = 0;
        _singletonCount   = 0;
        _showSingletons   = false;
        Navigation.NavigateTo("/");
    }

    private void ProcessRecords(List<RunRecord> records)
    {
        _runLabel     = records[0].TimestampUtc.ToString("o");
        _deployments  = records.Select(r => r.Deployment).Distinct().OrderBy(d => d).ToList();
        _successCount = records.Count(r => r.Status == 200);
        _errorCount   = records.Count(r => r.Error != null || r.Status != 200);

        _summaryRows = records
            .GroupBy(r => (r.TextLabel, r.QueryLabel, r.Deployment))
            .OrderBy(g => g.Key.TextLabel)
            .ThenBy(g => g.Key.QueryLabel)
            .ThenBy(g => g.Key.Deployment)
            .Select(g =>
            {
                var rs     = g.ToList();
                var ok     = rs.Where(r => r.Status == 200).ToList();
                int nOk    = ok.Count;
                int nErr   = rs.Count - nOk;
                bool isList  = rs[0].ListTask;
                bool isOrder = rs[0].OrderTask;
                int sections = rs[0].SectionCount;

                // counts
                string exact    = isList  && nOk > 0 ? ok.Average(r => r.ExactMatches).ToString("F1")   : "";
                string cov      = isList  && nOk > 0 ? ok.Average(r => r.Coverage).ToString("F1")        : "";
                string halluc   = isList  && nOk > 0 ? ok.Average(r => r.Hallucinations).ToString("F1")  : "";
                string li1Cnt   = isList  ? ok.Count(r => r.Li1First).ToString()                          : "";
                string posScore = isOrder && ok.Any(r => r.PositionScore.HasValue)
                    ? ok.Where(r => r.PositionScore.HasValue).Average(r => r.PositionScore!.Value).ToString("F1") : "";
                string minMoves = isOrder && ok.Any(r => r.MinMoves.HasValue)
                    ? ok.Where(r => r.MinMoves.HasValue).Average(r => r.MinMoves!.Value).ToString("F2")   : "";
                string titleCnt = !isList ? ok.Count(r => r.TitleHit).ToString()    : "";
                string tbCnt    = !isList ? ok.Count(r => r.TextbookHit).ToString() : "";

                var lpmVals    = ok.Where(r => r.ListLogprobMean.HasValue).Select(r => r.ListLogprobMean!.Value).ToList();
                var lpmMedVals = ok.Where(r => r.ListLogprobMedian.HasValue).Select(r => r.ListLogprobMedian!.Value).ToList();
                var tlpVals    = ok.Where(r => r.TitleLogprob.HasValue).Select(r => r.TitleLogprob!.Value).ToList();

                string lpMean  = lpmVals.Count    > 0 ? lpmVals.Average().ToString("F4")    : "";
                string lpMed   = lpmMedVals.Count > 0 ? lpmMedVals.Average().ToString("F4") : "";
                string tlpMean = tlpVals.Count    > 0 ? tlpVals.Average().ToString("F4")    : "";

                // percentages
                string nOkPct  = rs.Count > 0 ? (nOk  * 100.0 / rs.Count).ToString("F1") : "";
                string nErrPct = rs.Count > 0 ? (nErr * 100.0 / rs.Count).ToString("F1") : "";
                int perfCount  = ok.Count(r =>
                    (!r.ListTask  || (r.Coverage == r.SectionCount && r.Hallucinations == 0)) &&
                    (!r.OrderTask || r.MinMoves == 0) &&
                    (r.ListTask   || r.TitleHit));
                string perfPct  = nOk > 0 ? (perfCount * 100.0 / nOk).ToString("F1") : "";
                string covPct   = isList && sections > 0 && nOk > 0
                    ? (ok.Average(r => r.Coverage) / sections * 100).ToString("F1") : "";
                string li1Pct   = isList && nOk > 0
                    ? (ok.Count(r => r.Li1First) * 100.0 / nOk).ToString("F1") : "";
                string ordPct   = isOrder && ok.Any(r => r.OrderPct.HasValue)
                    ? ok.Where(r => r.OrderPct.HasValue).Average(r => r.OrderPct!.Value).ToString("F1") : "";
                string titlePct = !isList && nOk > 0
                    ? (ok.Count(r => r.TitleHit)    * 100.0 / nOk).ToString("F1") : "";
                string tbPct    = !isList && nOk > 0
                    ? (ok.Count(r => r.TextbookHit) * 100.0 / nOk).ToString("F1") : "";

                string lpmGeo    = lpmVals.Count    > 0 ? (Math.Exp(lpmVals.Average())                      * 100).ToString("F1") : "";
                string lpmAri    = lpmVals.Count    > 0 ? (lpmVals.Average(v => Math.Exp(v))                * 100).ToString("F1") : "";
                string lpmMedGeo = lpmMedVals.Count > 0 ? (Math.Exp(lpmMedVals.Average())                   * 100).ToString("F1") : "";
                string lpmMedAri = lpmMedVals.Count > 0 ? (lpmMedVals.Average(v => Math.Exp(v))             * 100).ToString("F1") : "";
                string tlpGeo    = tlpVals.Count    > 0 ? (Math.Exp(tlpVals.Average())                      * 100).ToString("F1") : "";
                string tlpAri    = tlpVals.Count    > 0 ? (tlpVals.Average(v => Math.Exp(v))                * 100).ToString("F1") : "";

                return new SummaryRow(
                    g.Key.TextLabel, g.Key.QueryLabel, g.Key.Deployment,
                    rs.Count, nOk, nErr,
                    exact, cov, halluc, li1Cnt, posScore, minMoves, titleCnt, tbCnt, lpMean, lpMed, tlpMean,
                    nOkPct, nErrPct, perfPct,
                    covPct, li1Pct, ordPct, titlePct, tbPct,
                    lpmGeo, lpmAri, lpmMedGeo, lpmMedAri, tlpGeo, tlpAri);
            })
            .ToList();

        _deploymentStats = records
            .GroupBy(r => r.Deployment)
            .Select(g =>
            {
                var ok     = g.Where(r => r.Status == 200).ToList();
                var tokens = ok.Where(r => r.CompletionTokens.HasValue)
                               .Select(r => r.CompletionTokens!.Value).ToList();
                int perfCount = ok.Count(r =>
                    (!r.ListTask  || (r.Coverage == r.SectionCount && r.Hallucinations == 0)) &&
                    (!r.OrderTask || r.MinMoves == 0) &&
                    (r.ListTask   || r.TitleHit));
                return new DeploymentStat(
                    g.Key, g.Count(), ok.Count, perfCount,
                    g.Count(r => r.Error != null || r.Status != 200),
                    ok.Count > 0 ? (long)ok.Average(r => r.DurationMs) : 0,
                    tokens.Count > 0 ? ((int)tokens.Average()).ToString() : "—");
            })
            .OrderBy(s => s.Deployment)
            .ToList();

        _allIdentityGroups = records
            .Where(r => r.Status == 200 && r.ContentSha256Short != null)
            .GroupBy(r => r.ContentSha256Short!)
            .Select(g =>
            {
                var first = g.First();
                string label = $"{first.TextLabel} · {first.QueryLabel}";
                return new IdentityGroup(
                    g.Key,
                    g.Count(),
                    g.Select(r => r.Deployment).Distinct().OrderBy(d => d).ToList(),
                    label);
            })
            .OrderByDescending(g => g.Count)
            .ToList();

        _totalGroups    = _allIdentityGroups.Count;
        _singletonCount = _allIdentityGroups.Count(g => g.Count == 1);
        _identityGroups = _allIdentityGroups.Where(g => g.Count >= 2).ToList();
    }
}
