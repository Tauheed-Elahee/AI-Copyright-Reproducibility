<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AICopyrightReproducibility.Gui.ViewModels"
        xmlns:conv="using:AICopyrightReproducibility.Gui.Converters"
        xmlns:sp="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        xmlns:ctrl="using:AICopyrightReproducibility.Gui.Controls"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        x:DataType="vm:MainViewModel"
        x:Class="AICopyrightReproducibility.Gui.Views.MainWindow"
        Title="{Binding WindowTitle}"
        Width="1100" Height="750"
        MinWidth="700" MinHeight="500">

  <Window.Resources>
    <ControlTemplate x:Key="LogFilterToggleTemplate" TargetType="ToggleButton">
      <Border Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="3"
              Padding="{TemplateBinding Padding}">
        <ContentPresenter HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Content="{TemplateBinding Content}"
                          Foreground="{TemplateBinding Foreground}" />
      </Border>
    </ControlTemplate>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="ToggleButton.log-filter">
      <Setter Property="Template"        Value="{StaticResource LogFilterToggleTemplate}"/>
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="BorderBrush"     Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground"      Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
      <Setter Property="Opacity"         Value="0.65"/>
    </Style>
    <Style Selector="ToggleButton.log-filter:pointerover">
      <Setter Property="Opacity" Value="0.8"/>
    </Style>
    <Style Selector="ToggleButton.log-filter:checked">
      <Setter Property="Opacity"   Value="1"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="ToggleButton.log-filter.log-v:checked">
      <Setter Property="Background"  Value="#606060"/>
      <Setter Property="BorderBrush" Value="#505050"/>
    </Style>
    <Style Selector="ToggleButton.log-filter.log-i:checked">
      <Setter Property="Background"  Value="{DynamicResource SystemAccentColor}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}"/>
    </Style>
    <Style Selector="ToggleButton.log-filter.log-w:checked">
      <Setter Property="Background"  Value="#C47A00"/>
      <Setter Property="BorderBrush" Value="#A06500"/>
    </Style>
    <Style Selector="ToggleButton.log-filter.log-e:checked">
      <Setter Property="Background"  Value="#C02828"/>
      <Setter Property="BorderBrush" Value="#A02020"/>
    </Style>
  </Window.Styles>

  <ui:FANavigationView x:Name="NavView"
                     PaneDisplayMode="Left"
                     IsBackButtonVisible="False"
                     IsSettingsVisible="False"
                     SelectionChanged="OnNavViewSelectionChanged">

    <ui:FANavigationView.MenuItems>
      <ui:FANavigationViewItem Content="Open" Tag="0" x:Name="NavOpen">
        <ui:FANavigationViewItem.IconSource>
          <ui:FASymbolIconSource Symbol="{x:Static ui:FASymbol.OpenFolder}" />
        </ui:FANavigationViewItem.IconSource>
      </ui:FANavigationViewItem>
      <ui:FANavigationViewItem Content="Experiments" Tag="1" x:Name="NavExperiments"
          IsEnabled="{Binding Settings, Converter={x:Static ObjectConverters.IsNotNull}}">
        <ui:FANavigationViewItem.IconSource>
          <ui:FASymbolIconSource Symbol="{x:Static ui:FASymbol.Edit}" />
        </ui:FANavigationViewItem.IconSource>
      </ui:FANavigationViewItem>
      <ui:FANavigationViewItem Content="Deployments" Tag="2" x:Name="NavDeployments"
          IsEnabled="{Binding HasProject}">
        <ui:FANavigationViewItem.IconSource>
          <ui:FASymbolIconSource Symbol="{x:Static ui:FASymbol.Cloud}" />
        </ui:FANavigationViewItem.IconSource>
      </ui:FANavigationViewItem>
      <ui:FANavigationViewItem Content="Secrets" Tag="3" x:Name="NavSecrets"
          IsEnabled="{Binding HasProject}">
        <ui:FANavigationViewItem.IconSource>
          <ui:FASymbolIconSource Symbol="{x:Static ui:FASymbol.Permissions}" />
        </ui:FANavigationViewItem.IconSource>
      </ui:FANavigationViewItem>
      <ui:FANavigationViewItem Content="Inputs" Tag="4" x:Name="NavInputs"
          IsEnabled="{Binding HasProject}">
        <ui:FANavigationViewItem.IconSource>
          <ui:FASymbolIconSource Symbol="{x:Static ui:FASymbol.BulletList}" />
        </ui:FANavigationViewItem.IconSource>
      </ui:FANavigationViewItem>
      <ui:FANavigationViewItem Content="Run" Tag="5" x:Name="NavRun"
          IsEnabled="{Binding HasProject}">
        <ui:FANavigationViewItem.IconSource>
          <ui:FASymbolIconSource Symbol="{x:Static ui:FASymbol.Play}" />
        </ui:FANavigationViewItem.IconSource>
      </ui:FANavigationViewItem>
      <ui:FANavigationViewItem Content="Output" Tag="6" x:Name="NavOutput"
          IsEnabled="{Binding IsOutputAvailable}">
        <ui:FANavigationViewItem.IconSource>
          <ui:FASymbolIconSource Symbol="{x:Static ui:FASymbol.SlideShow}" />
        </ui:FANavigationViewItem.IconSource>
      </ui:FANavigationViewItem>
    </ui:FANavigationView.MenuItems>

    <ui:FANavigationView.FooterMenuItems>
      <ui:FANavigationViewItem Content="Settings" Tag="7" x:Name="NavSettings">
        <ui:FANavigationViewItem.IconSource>
          <ui:FASymbolIconSource Symbol="{x:Static ui:FASymbol.Settings}" />
        </ui:FANavigationViewItem.IconSource>
      </ui:FANavigationViewItem>
      <ui:FANavigationViewItem Content="License" Tag="8" x:Name="NavLicense">
        <ui:FANavigationViewItem.IconSource>
          <ui:FASymbolIconSource Symbol="{x:Static ui:FASymbol.ProtectedDocument}" />
        </ui:FANavigationViewItem.IconSource>
      </ui:FANavigationViewItem>
      <ui:FANavigationViewItem Content="About" Tag="9" x:Name="NavAbout">
        <ui:FANavigationViewItem.IconSource>
          <ui:FASymbolIconSource Symbol="{x:Static ui:FASymbol.Help}" />
        </ui:FANavigationViewItem.IconSource>
      </ui:FANavigationViewItem>
    </ui:FANavigationView.FooterMenuItems>

    <!-- ── Content area ─────────────────────────────────────────────────── -->
    <Grid>

      <!-- ── Open ─────────────────────────────────────────────────────── -->
      <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" Margin="12" IsVisible="{Binding IsOpenPage}">

        <TextBlock Grid.Row="0" Text="Open Project" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,8">
          <TextBox Grid.Column="0"
                   Text="{Binding ProjectDir}"
                   PlaceholderText="Select or type project directory path…" />
          <Button Grid.Column="1" Content="Browse…"    Command="{Binding BrowseCommand}"     Margin="6,0,0,0" />
          <Button Grid.Column="2" Content="Load Config" Command="{Binding LoadConfigCommand}" Margin="6,0,0,0" />
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="Browse to or type a project directory, then click Load Config."
                   TextWrapping="Wrap" Margin="0,2,0,8"
                   IsVisible="{Binding Summary, Converter={x:Static ObjectConverters.IsNull}}" />

        <Border Grid.Row="3"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,8"
                IsVisible="{Binding Summary, Converter={x:Static ObjectConverters.IsNotNull}}">
          <Grid RowDefinitions="Auto,Auto">
            <TextBlock Grid.Row="0" FontWeight="Bold" FontSize="14" Text="{Binding Summary.ProjectName}" />
            <WrapPanel Grid.Row="1" Margin="0,6,0,0">
              <TextBlock FontSize="13" Text="{Binding Summary.Author, StringFormat='Author: {0}'}"
                         Margin="0,0,20,0"
                         IsVisible="{Binding Summary.Author, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
              <TextBlock FontSize="13" Text="{Binding Summary.DeploymentCount, StringFormat='Deployments: {0}'}" Margin="0,0,20,0" />
              <TextBlock FontSize="13" Text="{Binding Summary.BoundPromptCount, StringFormat='Prompts: {0}'}"    Margin="0,0,20,0" />
              <TextBlock FontSize="13" Text="{Binding Summary.Sets, StringFormat='Sets: {0}'}"                   Margin="0,0,20,0" />
              <TextBlock FontSize="13" Text="{Binding Summary.Reps, StringFormat='Reps: {0}'}"                   Margin="0,0,20,0" />
              <TextBlock FontSize="13" Text="{Binding Summary.TotalRuns, StringFormat='Total runs: {0}'}"        Margin="0,0,20,0" />
              <TextBlock FontSize="13" Text="READ-ONLY" Foreground="#FF7043" FontWeight="SemiBold"
                         IsVisible="{Binding Summary.IsReadOnly}" />
            </WrapPanel>
          </Grid>
        </Border>

        <TextBlock Grid.Row="4"
                   Text="{Binding ErrorMessage}" Foreground="#EF5350" FontWeight="SemiBold" TextWrapping="Wrap"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Margin="0,0,0,8" />

        <Grid Grid.Row="5" RowDefinitions="Auto,*" IsVisible="{Binding HasRecentProjects}">
          <TextBlock Grid.Row="0" Text="Recent" FontWeight="SemiBold" FontSize="13"
                     Margin="0,0,0,4" />
          <ItemsControl Grid.Row="1" ItemsSource="{Binding RecentProjects}" x:CompileBindings="False">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Command="{Binding $parent[ItemsControl].DataContext.OpenRecentCommand}"
                        CommandParameter="{Binding Path}"
                        HorizontalAlignment="Left" HorizontalContentAlignment="Left"
                        Margin="0,0,0,4">
                  <StackPanel>
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                    <TextBlock FontSize="12">
                      <Run Text="{Binding LastOpened, StringFormat='{}{0:yyyy-MM-dd}'}" />
                      <Run Text=" · " />
                      <Run Text="{Binding Path}" />
                    </TextBlock>
                  </StackPanel>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Grid>

      </Grid>

      <!-- ── Experiments ───────────────────────────────────────────────── -->
      <ScrollViewer Margin="12" HorizontalScrollBarVisibility="Disabled"
                    IsVisible="{Binding IsExperimentsPage}">
        <StackPanel DataContext="{Binding Settings}" Spacing="12" x:CompileBindings="False">

          <TextBlock Text="Experiments" FontWeight="Bold" FontSize="18" />

          <TextBlock Text="Experiment settings are embedded in project.json and cannot be edited here."
                     Foreground="#FF7043" IsVisible="{Binding !CanEdit}" TextWrapping="Wrap" />

          <StackPanel IsVisible="{Binding CanEdit}">

            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
              <StackPanel Spacing="6">
                <TextBlock Text="Iterations" FontWeight="SemiBold" FontSize="13" />
                <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Sets"         VerticalAlignment="Center" />
                  <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding Sets}" Minimum="1" Maximum="9999" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Reps per set" VerticalAlignment="Center" Margin="0,4,0,0" />
                  <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding Reps}" Minimum="1" Maximum="9999" Margin="0,4,0,0" />
                </Grid>
              </StackPanel>
            </Border>

            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
              <StackPanel Spacing="6">
                <TextBlock Text="Parallelism" FontWeight="SemiBold" FontSize="13" />
                <CheckBox Content="Parallel deployments" IsChecked="{Binding ParallelDeployment}" />
                <CheckBox Content="Parallel reps"        IsChecked="{Binding ParallelRep}" />
                <CheckBox Content="Parallel prompts"     IsChecked="{Binding ParallelPrompt}" />
                <Grid ColumnDefinitions="160,*,Auto" Margin="0,4,0,0">
                  <TextBlock Grid.Column="0" Text="Max concurrency" VerticalAlignment="Center" />
                  <NumericUpDown Grid.Column="1" Value="{Binding MaxConcurrency}" Minimum="0" Maximum="9999" />
                  <TextBlock Grid.Column="2" Text="  (0 = unlimited)" VerticalAlignment="Center"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                </Grid>
              </StackPanel>
            </Border>

            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
              <StackPanel Spacing="6">
                <TextBlock Text="Retry" FontWeight="SemiBold" FontSize="13" />
                <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Max attempts"      VerticalAlignment="Center" />
                  <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding RetryMaxAttempts}"   Minimum="1" Maximum="99" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Initial delay (s)" VerticalAlignment="Center" Margin="0,4,0,0" />
                  <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding RetryInitialDelayS}" Minimum="0" Increment="0.5" FormatString="F1" Margin="0,4,0,0" />
                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Max delay (s)"     VerticalAlignment="Center" Margin="0,4,0,0" />
                  <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding RetryMaxDelayS}"     Minimum="0" Increment="5"   FormatString="F1" Margin="0,4,0,0" />
                </Grid>
              </StackPanel>
            </Border>

            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
              <StackPanel Spacing="6">
                <TextBlock Text="Timing pauses (seconds)" FontWeight="SemiBold" FontSize="13" />
                <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Between sets"        VerticalAlignment="Center" />
                  <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding PauseSetS}"        Minimum="0" Maximum="86400" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Between prompts"     VerticalAlignment="Center" Margin="0,4,0,0" />
                  <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding PausePromptS}"     Minimum="0" Maximum="86400" Margin="0,4,0,0" />
                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Between reps"        VerticalAlignment="Center" Margin="0,4,0,0" />
                  <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding PauseRepS}"        Minimum="0" Maximum="86400" Margin="0,4,0,0" />
                  <TextBlock Grid.Row="3" Grid.Column="0" Text="Between deployments" VerticalAlignment="Center" Margin="0,4,0,0" />
                  <NumericUpDown Grid.Row="3" Grid.Column="1" Value="{Binding PauseDeploymentS}" Minimum="0" Maximum="86400" Margin="0,4,0,0" />
                </Grid>
              </StackPanel>
            </Border>

            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
              <StackPanel Spacing="6">
                <TextBlock Text="Random seeds" FontWeight="SemiBold" FontSize="13" />
                <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Prompt shuffle"     VerticalAlignment="Center" />
                  <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding SeedShufflePrompt}"     Minimum="0" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Deployment shuffle" VerticalAlignment="Center" Margin="0,4,0,0" />
                  <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding SeedShuffleDeployment}" Minimum="0" Margin="0,4,0,0" />
                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Content shuffle"    VerticalAlignment="Center" Margin="0,4,0,0" />
                  <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding SeedShuffleContent}"    Minimum="0" Margin="0,4,0,0" />
                </Grid>
              </StackPanel>
            </Border>

            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
              <StackPanel Spacing="6">
                <TextBlock Text="Output" FontWeight="SemiBold" FontSize="13" />
                <Grid ColumnDefinitions="160,*">
                  <TextBlock Grid.Column="0" Text="Log level" VerticalAlignment="Center" />
                  <ComboBox Grid.Column="1"
                            SelectedItem="{Binding LogLevel}"
                            ItemsSource="{x:Static vm:ExperimentSettingsViewModel.LogLevels}" />
                </Grid>
                <CheckBox Content="Omit null fields from manifest JSON"
                          IsChecked="{Binding OmitNullFields}" Margin="0,4,0,0" />
              </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="12">
              <Button Content="Save settings" Command="{Binding SaveCommand}" />
              <TextBlock Text="Saved ✓" Foreground="#66BB6A" FontWeight="SemiBold" VerticalAlignment="Center"
                         IsVisible="{Binding SaveSuccess}" />
              <TextBlock Text="{Binding SaveError}" Foreground="#EF5350" VerticalAlignment="Center"
                         IsVisible="{Binding SaveError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>

          </StackPanel>
        </StackPanel>
      </ScrollViewer>

      <!-- ── Deployments ───────────────────────────────────────────────── -->
      <ScrollViewer Margin="12" IsVisible="{Binding IsDeploymentsPage}">
        <StackPanel x:CompileBindings="False" Spacing="14">

          <TextBlock Text="Deployments" FontWeight="Bold" FontSize="18" />

          <TextBlock Text="No deployments configured."
                     IsVisible="{Binding !Deployments.HasItems}" />

          <ItemsControl ItemsSource="{Binding Deployments.Items}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="14,12" Margin="0,0,0,10">
                  <Grid RowDefinitions="Auto,Auto">

                    <!-- Name + mode badge -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding Label}"
                                 FontWeight="Bold" FontSize="14"
                                 VerticalAlignment="Center" />
                      <Border Grid.Column="1"
                              BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                              BorderThickness="1" CornerRadius="3" Padding="6,2">
                        <TextBlock Text="{Binding Mode}" FontSize="12" FontWeight="SemiBold" />
                      </Border>
                    </Grid>

                    <!-- Body: endpoint + parameters -->
                    <StackPanel Grid.Row="1" Margin="0,10,0,0" Spacing="6"
                                IsVisible="{Binding HasBody}">

                      <Grid ColumnDefinitions="110,*" IsVisible="{Binding HasEndpoint}">
                        <TextBlock Grid.Column="0"
                                   Text="Endpoint"
                                   FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Top" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Endpoint}"
                                   FontSize="13" TextWrapping="Wrap" />
                      </Grid>

                      <ItemsControl ItemsSource="{Binding Parameters}"
                                    IsVisible="{Binding HasParameters}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="110,*" Margin="0,0,0,3">
                              <TextBlock Grid.Column="0"
                                         Text="{Binding Key}"
                                         FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                                         FontSize="12" FontWeight="SemiBold" />
                              <TextBlock Grid.Column="1"
                                         Text="{Binding Value}"
                                         FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                                         FontSize="13" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>

                    </StackPanel>

                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

        </StackPanel>
      </ScrollViewer>

      <!-- ── Secrets ───────────────────────────────────────────────────── -->
      <ScrollViewer Margin="12" IsVisible="{Binding IsSecretsPage}">
        <StackPanel x:CompileBindings="False" Spacing="12">

          <TextBlock Text="Secrets" FontWeight="Bold" FontSize="18" />

          <TextBlock Text="No secrets file found (config/secrets.json)."
                     IsVisible="{Binding !Secrets.HasItems}"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                     Margin="0,8" />

          <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                  BorderThickness="1" CornerRadius="4" Padding="10,8"
                  IsVisible="{Binding Secrets.HasItems}">
            <StackPanel>
              <TextBlock Text="Keys" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8" />
              <ItemsControl ItemsSource="{Binding Secrets.Items}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="200,*,Auto" Margin="0,3,0,3">
                      <TextBlock Grid.Column="0" Text="{Binding Key}"
                                 FontFamily="Cascadia Code,Consolas,Menlo,monospace" FontSize="13"
                                 VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1" Text="{Binding DisplayValue}"
                                 FontFamily="Cascadia Code,Consolas,Menlo,monospace" FontSize="13"
                                 VerticalAlignment="Center" />
                      <ToggleButton Grid.Column="2" Content="Show" IsChecked="{Binding ShowValue}"
                                    Padding="8,2" FontSize="12" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

      <!-- ── Inputs ────────────────────────────────────────────────────── -->
      <Grid RowDefinitions="Auto,*" Margin="12,8,12,12" IsVisible="{Binding IsInputsPage}">
        <TextBlock Grid.Row="0" Text="Inputs" FontWeight="Bold" FontSize="18" Margin="0,0,0,4" />
      <TabControl Grid.Row="1" x:CompileBindings="False">

        <TabItem Header="{Binding Inputs.TextsHeader}">
          <Grid Margin="0,8,0,0" RowDefinitions="*,Auto">

            <!-- Read-only path: texts embedded in project.json or no file -->
            <Grid Grid.Row="0" RowDefinitions="Auto,Auto,*"
                  IsVisible="{Binding !Inputs.CanEditTexts}">
              <TextBlock Grid.Row="0"
                         Text="No texts loaded."
                         IsVisible="{Binding !Inputs.HasTexts}"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <TextBlock Grid.Row="1"
                         Text="Texts are embedded in project.json and cannot be edited here."
                         Foreground="#FF7043" TextWrapping="Wrap"
                         IsVisible="{Binding Inputs.HasTexts}"
                         Margin="0,0,0,8" />
              <DataGrid Grid.Row="2"
                        ItemsSource="{Binding Inputs.Texts}"
                        AutoGenerateColumns="False" IsReadOnly="True"
                        GridLinesVisibility="Horizontal"
                        IsVisible="{Binding Inputs.HasTexts}">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Label"    Binding="{Binding Label}"        Width="160" />
                  <DataGridTextColumn Header="Title"    Binding="{Binding TitleFull}"     Width="*" />
                  <DataGridTextColumn Header="Sections" Binding="{Binding SectionCount}"  Width="80" />
                </DataGrid.Columns>
              </DataGrid>
            </Grid>

            <!-- Editable path: texts in a separate file -->
            <Grid Grid.Row="0" ColumnDefinitions="180,4,*"
                  IsVisible="{Binding Inputs.CanEditTexts}">

              <!-- Left: list + add / delete -->
              <Grid Grid.Column="0" RowDefinitions="*,Auto">
                <ListBox Grid.Row="0"
                         ItemsSource="{Binding Inputs.Texts}"
                         SelectedItem="{Binding Inputs.SelectedText}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                  <Button Content="Add"    Command="{Binding Inputs.AddTextCommand}"    Padding="8,3" FontSize="12" />
                  <Button Content="Delete" Command="{Binding Inputs.DeleteTextCommand}" Padding="8,3" FontSize="12" />
                </StackPanel>
              </Grid>

              <!-- Splitter -->
              <GridSplitter Grid.Column="1" ResizeBehavior="PreviousAndNext" />

              <!-- Right: edit form -->
              <ScrollViewer Grid.Column="2" Padding="12,0,0,0"
                            IsVisible="{Binding Inputs.SelectedText, Converter={x:Static ObjectConverters.IsNotNull}}">
                <StackPanel Spacing="8" DataContext="{Binding Inputs.SelectedText}">

                  <TextBlock Text="Label" FontWeight="SemiBold" FontSize="12" />
                  <TextBox Text="{Binding Label}" />

                  <TextBlock Text="Title (full)" FontWeight="SemiBold" FontSize="12" />
                  <TextBox Text="{Binding TitleFull}" />

                  <TextBlock Text="Title (short)" FontWeight="SemiBold" FontSize="12" />
                  <TextBox Text="{Binding TitleShort}" />

                  <!-- Section Headings header with mode toggle -->
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Section Headings"
                               FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="{Binding SectionModeButtonText}"
                            Command="{Binding ToggleSectionModeCommand}"
                            Padding="8,2" FontSize="11" />
                  </Grid>

                  <!-- List mode (default) -->
                  <StackPanel IsVisible="{Binding !IsSectionMassEditMode}" Spacing="4">
                    <ItemsControl ItemsSource="{Binding SectionRows}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,2">
                            <TextBox Grid.Column="0" Text="{Binding Text}" PlaceholderText="heading" />
                            <Button Grid.Column="1" Content="×" Margin="4,0,0,0"
                                    Command="{Binding $parent[ItemsControl].DataContext.DeleteSectionCommand}"
                                    CommandParameter="{Binding}"
                                    Padding="6,2" FontSize="12" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="+ Add heading" Command="{Binding AddSectionCommand}"
                            Padding="8,3" FontSize="12" HorizontalAlignment="Left" />
                  </StackPanel>

                  <!-- Mass edit mode -->
                  <StackPanel IsVisible="{Binding IsSectionMassEditMode}" Spacing="4">
                    <TextBlock Text="one heading per line" FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBox Text="{Binding SectionHeadings}"
                             AcceptsReturn="True" MinHeight="80" TextWrapping="Wrap" />
                  </StackPanel>

                  <TextBlock Text="Aliases" FontWeight="SemiBold" FontSize="12" />
                  <ItemsControl ItemsSource="{Binding AliasRows}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid ColumnDefinitions="*,Auto,*,Auto" Margin="0,2,0,2">
                          <TextBox Grid.Column="0" Text="{Binding Key}"   PlaceholderText="key" />
                          <TextBlock Grid.Column="1" Text=" → "
                                     VerticalAlignment="Center" Margin="4,0" />
                          <ctrl:NavAutoCompleteBox Grid.Column="2"
                                               Text="{Binding Value}"
                                               ItemsSource="{Binding $parent[ItemsControl].DataContext.SectionHeadingTexts}"
                                               FilterMode="ContainsOrdinal"
                                               MinimumPrefixLength="0"
                                               PlaceholderText="heading…" />
                          <Button Grid.Column="3" Content="×" Margin="4,0,0,0"
                                  Command="{Binding $parent[ItemsControl].DataContext.DeleteAliasCommand}"
                                  CommandParameter="{Binding}"
                                  Padding="6,2" FontSize="12" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <Button Content="+ Add alias" Command="{Binding AddAliasCommand}"
                          Padding="8,3" FontSize="12" HorizontalAlignment="Left" />

                </StackPanel>
              </ScrollViewer>

            </Grid>

            <!-- Save bar (editable path only) -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12"
                        Margin="0,8,0,0" IsVisible="{Binding Inputs.CanEditTexts}">
              <Button Content="Save texts" Command="{Binding Inputs.SaveTextsCommand}" />
              <TextBlock Text="Saved ✓" Foreground="#66BB6A" FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         IsVisible="{Binding Inputs.TextsSaveSuccess}" />
              <TextBlock Text="{Binding Inputs.TextsSaveError}" Foreground="#EF5350"
                         VerticalAlignment="Center"
                         IsVisible="{Binding Inputs.TextsSaveError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>

          </Grid>
        </TabItem>

        <TabItem Header="{Binding Inputs.QueriesHeader}">
          <Grid Margin="0,8,0,0" RowDefinitions="*,Auto">

            <!-- Read-only path: queries embedded in project.json or no file -->
            <Grid Grid.Row="0" RowDefinitions="Auto,Auto,*"
                  IsVisible="{Binding !Inputs.CanEditQueries}">
              <TextBlock Grid.Row="0"
                         Text="No queries loaded."
                         IsVisible="{Binding !Inputs.HasQueries}"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <TextBlock Grid.Row="1"
                         Text="Queries are embedded in project.json and cannot be edited here."
                         Foreground="#FF7043" TextWrapping="Wrap"
                         IsVisible="{Binding Inputs.HasQueries}"
                         Margin="0,0,0,8" />
              <DataGrid Grid.Row="2"
                        ItemsSource="{Binding Inputs.Queries}"
                        AutoGenerateColumns="False" IsReadOnly="True"
                        GridLinesVisibility="Horizontal"
                        IsVisible="{Binding Inputs.HasQueries}">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Label"       Binding="{Binding Label}"            Width="160" />
                  <DataGridTextColumn Header="Types"       Binding="{Binding Types}"             Width="160" />
                  <DataGridTextColumn Header="User prompt" Binding="{Binding UserPromptPreview}" Width="*" />
                </DataGrid.Columns>
              </DataGrid>
            </Grid>

            <!-- Editable path: queries in a separate file -->
            <Grid Grid.Row="0" ColumnDefinitions="180,4,*"
                  IsVisible="{Binding Inputs.CanEditQueries}">

              <!-- Left: list + add / delete -->
              <Grid Grid.Column="0" RowDefinitions="*,Auto">
                <ListBox Grid.Row="0"
                         ItemsSource="{Binding Inputs.Queries}"
                         SelectedItem="{Binding Inputs.SelectedQuery}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                  <Button Content="Add"    Command="{Binding Inputs.AddQueryCommand}"    Padding="8,3" FontSize="12" />
                  <Button Content="Delete" Command="{Binding Inputs.DeleteQueryCommand}" Padding="8,3" FontSize="12" />
                </StackPanel>
              </Grid>

              <!-- Splitter -->
              <GridSplitter Grid.Column="1" ResizeBehavior="PreviousAndNext" />

              <!-- Right: edit form -->
              <ScrollViewer Grid.Column="2" Padding="12,0,0,0"
                            IsVisible="{Binding Inputs.SelectedQuery, Converter={x:Static ObjectConverters.IsNotNull}}">
                <StackPanel Spacing="8" DataContext="{Binding Inputs.SelectedQuery}">
                  <TextBlock Text="Label" FontWeight="SemiBold" FontSize="12" />
                  <TextBox Text="{Binding Label}" />
                  <TextBlock Text="Types" FontWeight="SemiBold" FontSize="12" />
                  <ItemsControl ItemsSource="{Binding TypeRows}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,2">
                          <ctrl:NavAutoCompleteBox Grid.Column="0"
                                               Text="{Binding Text}"
                                               ItemsSource="{Binding AvailableTypeSuggestions}"
                                               FilterMode="ContainsOrdinal"
                                               MinimumPrefixLength="0"
                                               PlaceholderText="type…" />
                          <Button Grid.Column="1" Content="×" Margin="4,0,0,0"
                                  Command="{Binding $parent[ItemsControl].DataContext.DeleteTypeCommand}"
                                  CommandParameter="{Binding}"
                                  Padding="6,2" FontSize="12" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <Button Content="+ Add type" Command="{Binding AddTypeCommand}"
                          Padding="8,3" FontSize="12" HorizontalAlignment="Left" />
                  <TextBlock Text="System Message" FontWeight="SemiBold" FontSize="12" />
                  <TextBox Text="{Binding SystemMessage}"
                           AcceptsReturn="True" MinHeight="60" TextWrapping="Wrap" />
                  <TextBlock Text="User Prompt" FontWeight="SemiBold" FontSize="12" />
                  <TextBox Text="{Binding UserPrompt}"
                           AcceptsReturn="True" MinHeight="120" TextWrapping="Wrap" />
                </StackPanel>
              </ScrollViewer>

            </Grid>

            <!-- Save bar (editable path only) -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12"
                        Margin="0,8,0,0" IsVisible="{Binding Inputs.CanEditQueries}">
              <Button Content="Save queries" Command="{Binding Inputs.SaveQueriesCommand}" />
              <TextBlock Text="Saved ✓" Foreground="#66BB6A" FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         IsVisible="{Binding Inputs.QueriesSaveSuccess}" />
              <TextBlock Text="{Binding Inputs.QueriesSaveError}" Foreground="#EF5350"
                         VerticalAlignment="Center"
                         IsVisible="{Binding Inputs.QueriesSaveError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>

          </Grid>
        </TabItem>

        <TabItem Header="{Binding Inputs.PromptsHeader}">
          <Grid Margin="0,8,0,0" RowDefinitions="*,Auto">

            <!-- Read-only path: prompts embedded in project.json or no file -->
            <Grid Grid.Row="0" RowDefinitions="Auto,Auto,*"
                  IsVisible="{Binding !Inputs.CanEditPrompts}">
              <TextBlock Grid.Row="0"
                         Text="No prompts loaded."
                         IsVisible="{Binding !Inputs.HasPrompts}"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <TextBlock Grid.Row="1"
                         Text="Prompts are embedded in project.json and cannot be edited here."
                         Foreground="#FF7043" TextWrapping="Wrap"
                         IsVisible="{Binding Inputs.HasPrompts}"
                         Margin="0,0,0,8" />
              <DataGrid Grid.Row="2"
                        ItemsSource="{Binding Inputs.PromptRows}"
                        AutoGenerateColumns="False" IsReadOnly="True"
                        GridLinesVisibility="Horizontal"
                        IsVisible="{Binding Inputs.HasPrompts}">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Text"    Binding="{Binding TextLabel}"      Width="160" />
                  <DataGridTextColumn Header="Queries" Binding="{Binding QueriesSummary}" Width="*" />
                </DataGrid.Columns>
              </DataGrid>
            </Grid>

            <!-- Editable path: prompts in a separate file -->
            <Grid Grid.Row="0" ColumnDefinitions="180,4,*"
                  IsVisible="{Binding Inputs.CanEditPrompts}">

              <!-- Left: list + add / delete -->
              <Grid Grid.Column="0" RowDefinitions="*,Auto">
                <ListBox Grid.Row="0"
                         ItemsSource="{Binding Inputs.PromptRows}"
                         SelectedItem="{Binding Inputs.SelectedPrompt}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding TextLabel}" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                  <Button Content="Add"    Command="{Binding Inputs.AddPromptCommand}"    Padding="8,3" FontSize="12" />
                  <Button Content="Delete" Command="{Binding Inputs.DeletePromptCommand}" Padding="8,3" FontSize="12" />
                </StackPanel>
              </Grid>

              <!-- Splitter -->
              <GridSplitter Grid.Column="1" ResizeBehavior="PreviousAndNext" />

              <!-- Right: edit form -->
              <ScrollViewer Grid.Column="2" Padding="12,0,0,0"
                            IsVisible="{Binding Inputs.SelectedPrompt, Converter={x:Static ObjectConverters.IsNotNull}}">
                <StackPanel Spacing="8" DataContext="{Binding Inputs.SelectedPrompt}">
                  <TextBlock Text="Text Label" FontWeight="SemiBold" FontSize="12" />
                  <TextBox Text="{Binding TextLabel}" />
                  <TextBlock Text="Queries" FontWeight="SemiBold" FontSize="12" />
                  <ItemsControl ItemsSource="{Binding QueryLinkRows}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,2">
                          <ctrl:NavAutoCompleteBox Grid.Column="0"
                                               Text="{Binding QueryLabel}"
                                               ItemsSource="{Binding AvailableQuerySuggestions}"
                                               FilterMode="ContainsOrdinal"
                                               MinimumPrefixLength="0"
                                               PlaceholderText="query…" />
                          <Button Grid.Column="1" Content="×" Margin="4,0,0,0"
                                  Command="{Binding $parent[ItemsControl].DataContext.DeleteQueryLinkCommand}"
                                  CommandParameter="{Binding}"
                                  Padding="6,2" FontSize="12" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <Button Content="+ Add query" Command="{Binding AddQueryLinkCommand}"
                          Padding="8,3" FontSize="12" HorizontalAlignment="Left" />
                </StackPanel>
              </ScrollViewer>

            </Grid>

            <!-- Save bar (editable path only) -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12"
                        Margin="0,8,0,0" IsVisible="{Binding Inputs.CanEditPrompts}">
              <Button Content="Save prompts" Command="{Binding Inputs.SavePromptsCommand}" />
              <TextBlock Text="Saved ✓" Foreground="#66BB6A" FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         IsVisible="{Binding Inputs.PromptsSaveSuccess}" />
              <TextBlock Text="{Binding Inputs.PromptsSaveError}" Foreground="#EF5350"
                         VerticalAlignment="Center"
                         IsVisible="{Binding Inputs.PromptsSaveError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>

          </Grid>
        </TabItem>

      </TabControl>
      </Grid>

      <!-- ── Run ───────────────────────────────────────────────────────── -->
      <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" Margin="12" IsVisible="{Binding IsRunPage}">

        <Border Grid.Row="0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0">
              <TextBlock FontWeight="Bold" FontSize="14" Text="{Binding Summary.ProjectName}" />
              <TextBlock FontSize="12" Margin="0,2,0,6" Text="{Binding ProjectDir}"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <WrapPanel>
                <TextBlock Text="{Binding Summary.Author, StringFormat='Author: {0}'}"
                           Margin="0,0,20,0"
                           IsVisible="{Binding Summary.Author, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <TextBlock Text="{Binding Summary.DeploymentCount, StringFormat='Deployments: {0}'}" Margin="0,0,20,0" />
                <TextBlock Text="{Binding Summary.BoundPromptCount, StringFormat='Prompts: {0}'}"    Margin="0,0,20,0" />
                <TextBlock Text="{Binding Summary.Sets, StringFormat='Sets: {0}'}"                   Margin="0,0,20,0" />
                <TextBlock Text="{Binding Summary.Reps, StringFormat='Reps: {0}'}"                   Margin="0,0,20,0" />
                <TextBlock Text="{Binding Summary.TotalRuns, StringFormat='Total runs: {0}'}"        Margin="0,0,20,0" />
              </WrapPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
              <TextBlock Text="READ-ONLY — run not allowed"
                         Foreground="#FF7043" FontWeight="SemiBold"
                         IsVisible="{Binding Summary.IsReadOnly}" />
              <Button Content="Run Experiment" Command="{Binding RunCommand}"
                      IsVisible="{Binding !Summary.IsReadOnly}" />
            </StackPanel>
          </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto"
              IsVisible="{Binding IsRunning}" Margin="0,0,0,4">
          <ProgressBar Grid.Column="0" Minimum="0"
                       Maximum="{Binding ProgressTotal}" Value="{Binding ProgressCompleted}" />
          <StackPanel Grid.Column="1" Orientation="Horizontal"
                      Margin="8,0,6,0" VerticalAlignment="Center" Spacing="0">
            <TextBlock Text="{Binding ProgressCompleted}" />
            <TextBlock Text=" / " />
            <TextBlock Text="{Binding ProgressTotal}" />
          </StackPanel>
          <Button Grid.Column="2" Content="Cancel" Command="{Binding CancelCommand}" />
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="{Binding CurrentOperation}" FontSize="12"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                   IsVisible="{Binding CurrentOperation, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Margin="0,0,0,4" />

        <Border Grid.Row="3" CornerRadius="4" Padding="10,6" Margin="0,0,0,6"
                Background="#1566BB6A" IsVisible="{Binding IsRunCompleted}">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="Run complete — results are ready."
                       FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="View Output →" Command="{Binding GoToOutputCommand}" />
          </Grid>
        </Border>
        <Border Grid.Row="3" CornerRadius="4" Padding="10,6" Margin="0,0,0,6"
                Background="#15EF5350" IsVisible="{Binding IsRunFailed}">
          <TextBlock Text="Run failed — see error below." FontWeight="SemiBold" Foreground="#EF5350" />
        </Border>

        <Border Grid.Row="4"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                BorderThickness="1" CornerRadius="4" Margin="0,0,0,6">
          <Grid RowDefinitions="Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto"
                  Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
              <TextBlock Grid.Column="0" Text="Log" FontWeight="SemiBold" Margin="8,4" VerticalAlignment="Center" />
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" Margin="0,2,4,2">
                <Button Content="All"  Command="{Binding SelectAllLogsCommand}"
                        Padding="6,2" FontSize="12" ToolTip.Tip="Show all levels" />
                <Button Content="None" Command="{Binding SelectNoneLogsCommand}"
                        Padding="6,2" FontSize="12" ToolTip.Tip="Hide all levels" />
                <Rectangle Width="1" Fill="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           Margin="4,2" VerticalAlignment="Stretch" />
                <ToggleButton Classes="log-filter log-v" IsChecked="{Binding ShowVerbose}"
                              Content="Verb" ToolTip.Tip="Verbose" Padding="6,2" FontSize="12"
                              FontFamily="Cascadia Code,Consolas,Menlo,monospace" />
                <ToggleButton Classes="log-filter log-i" IsChecked="{Binding ShowInfo}"
                              Content="Info" ToolTip.Tip="Info"    Padding="6,2" FontSize="12"
                              FontFamily="Cascadia Code,Consolas,Menlo,monospace" />
                <ToggleButton Classes="log-filter log-w" IsChecked="{Binding ShowWarning}"
                              Content="Warn" ToolTip.Tip="Warning" Padding="6,2" FontSize="12"
                              FontFamily="Cascadia Code,Consolas,Menlo,monospace" />
                <ToggleButton Classes="log-filter log-e" IsChecked="{Binding ShowError}"
                              Content="Error" ToolTip.Tip="Error"  Padding="6,2" FontSize="12"
                              FontFamily="Cascadia Code,Consolas,Menlo,monospace" />
              </StackPanel>
            </Grid>
            <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer"
                          HorizontalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding LogLines}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:LogLine">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{Binding Level, Converter={x:Static conv:LogLevelBrushConverter.Instance}}"
                               FontFamily="Cascadia Code,Consolas,Menlo,monospace" FontSize="12"
                               TextWrapping="NoWrap" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Border>

        <TextBlock Grid.Row="5"
                   Text="{Binding ErrorMessage}" Foreground="#EF5350" FontWeight="SemiBold" TextWrapping="Wrap"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Margin="0,0,0,6" />

      </Grid>

      <!-- ── Output ────────────────────────────────────────────────────── -->
      <Grid RowDefinitions="Auto,Auto,*" Margin="12,8,12,12" IsVisible="{Binding IsOutputPage}">

        <TextBlock Grid.Row="0" Text="Output" FontWeight="Bold" FontSize="18" Margin="0,0,0,4" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8"
                    x:CompileBindings="False">
          <ComboBox ItemsSource="{Binding AvailableRuns}"
                    SelectedItem="{Binding SelectedRunOption}"
                    IsVisible="{Binding HasRunSelector}" MinWidth="220">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Label}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button Content="Open output folder"
                  Command="{Binding OpenOutputFolderCommand}"
                  IsVisible="{Binding OutputDir, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>

        <TabControl Grid.Row="2" x:CompileBindings="False">

          <TabItem Header="Table">
            <ScrollViewer Padding="0,8,0,0">
              <StackPanel Spacing="8">
                <TextBlock Text="No results yet."
                           IsVisible="{Binding !HasResults}"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        BorderThickness="1" CornerRadius="4" IsVisible="{Binding HasResults}">
                  <DataGrid ItemsSource="{Binding Results}"
                            AutoGenerateColumns="False" IsReadOnly="True"
                            GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                      <DataGridTextColumn Header="Deployment" Binding="{Binding Deployment}" Width="*" />
                      <DataGridTextColumn Header="Success"    Binding="{Binding SuccessCount}" Width="80" />
                      <DataGridTextColumn Header="Errors"     Binding="{Binding ErrorCount}"   Width="80" />
                      <DataGridTextColumn Header="Total"      Binding="{Binding TotalRuns}"    Width="70" />
                      <DataGridTextColumn Header="Success %"  Binding="{Binding SuccessRatePct, StringFormat=F0}" Width="90" />
                      <DataGridTextColumn Header="Avg ms"     Binding="{Binding AvgDurationMs, StringFormat=F0}" Width="90" />
                    </DataGrid.Columns>
                  </DataGrid>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="Charts" IsEnabled="{Binding Charts.HasData}"
                   ToolTip.Tip="Run an experiment first to populate charts"
                   ToolTip.ShowOnDisabled="True">
            <ScrollViewer Padding="0,8,0,0">
              <StackPanel Spacing="12" Margin="0,0,0,8">
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="8,6">
                  <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="Success Rate"
                               FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4" />
                    <sp:AvaPlot Grid.Row="1" x:Name="SuccessChart" Height="300" />
                  </Grid>
                </Border>
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="8,6">
                  <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="Duration Distribution"
                               FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4" />
                    <sp:AvaPlot Grid.Row="1" x:Name="DurationChart" Height="300" />
                  </Grid>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

        </TabControl>
      </Grid>

      <!-- ── Settings (stub) ───────────────────────────────────────────── -->
      <StackPanel Margin="12" Spacing="8" IsVisible="{Binding IsSettingsPage}">
        <TextBlock Text="Settings" FontWeight="Bold" FontSize="18" />
        <TextBlock Text="Application settings coming soon."
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
      </StackPanel>

      <!-- ── License ───────────────────────────────────────────────────── -->
      <ScrollViewer Margin="12" IsVisible="{Binding IsLicensePage}">
        <StackPanel Spacing="12" MaxWidth="740">
          <TextBlock Text="License" FontWeight="Bold" FontSize="18" />
          <TextBlock Text="PolyForm Strict License 1.0.0" FontWeight="SemiBold" FontSize="14" />
          <HyperlinkButton NavigateUri="https://polyformproject.org/licenses/strict/1.0.0"
                           Content="https://polyformproject.org/licenses/strict/1.0.0"
                           Padding="0" />

          <TextBlock Text="Acceptance" FontWeight="SemiBold" FontSize="15" />
          <TextBlock TextWrapping="Wrap"
                     Text="In order to get any license under these terms, you must agree to them as both strict obligations and conditions to all your licenses." />

          <TextBlock Text="Copyright License" FontWeight="SemiBold" FontSize="15" />
          <TextBlock TextWrapping="Wrap"
                     Text="The licensor grants you a copyright license for the software to do everything you might do with the software that would otherwise infringe the licensor's copyright in it for any permitted purpose, other than distributing the software or making changes or new works based on the software." />

          <TextBlock Text="Patent License" FontWeight="SemiBold" FontSize="15" />
          <TextBlock TextWrapping="Wrap"
                     Text="The licensor grants you a patent license for the software that covers patent claims the licensor can license, or becomes able to license, that you would infringe by using the software." />

          <TextBlock Text="Noncommercial Purposes" FontWeight="SemiBold" FontSize="15" />
          <TextBlock TextWrapping="Wrap"
                     Text="Any noncommercial purpose is a permitted purpose." />

          <TextBlock Text="Personal Uses" FontWeight="SemiBold" FontSize="15" />
          <TextBlock TextWrapping="Wrap"
                     Text="Personal use for research, experiment, and testing for the benefit of public knowledge, personal study, private entertainment, hobby projects, amateur pursuits, or religious observance, without any anticipated commercial application, is use for a permitted purpose." />

          <TextBlock Text="Noncommercial Organizations" FontWeight="SemiBold" FontSize="15" />
          <TextBlock TextWrapping="Wrap"
                     Text="Use by any charitable organization, educational institution, public research organization, public safety or health organization, environmental protection organization, or government institution is use for a permitted purpose regardless of the source of funding or obligations resulting from the funding." />

          <TextBlock Text="Fair Use" FontWeight="SemiBold" FontSize="15" />
          <TextBlock TextWrapping="Wrap"
                     Text='You may have "fair use" rights for the software under the law. These terms do not limit them.' />

          <TextBlock Text="No Other Rights" FontWeight="SemiBold" FontSize="15" />
          <TextBlock TextWrapping="Wrap"
                     Text="These terms do not allow you to sublicense or transfer any of your licenses to anyone else, or prevent the licensor from granting licenses to anyone else. These terms do not imply any other licenses." />

          <TextBlock Text="Patent Defense" FontWeight="SemiBold" FontSize="15" />
          <TextBlock TextWrapping="Wrap"
                     Text="If you make any written claim that the software infringes or contributes to infringement of any patent, your patent license for the software granted under these terms ends immediately. If your company makes such a claim, your patent license ends immediately for work on behalf of your company." />

          <TextBlock Text="Violations" FontWeight="SemiBold" FontSize="15" />
          <TextBlock TextWrapping="Wrap"
                     Text="The first time you are notified in writing that you have violated any of these terms, or done anything with the software not covered by your licenses, your licenses can nonetheless continue if you come into full compliance with these terms, and take practical steps to correct past violations, within 32 days of receiving notice. Otherwise, all your licenses end immediately." />

          <TextBlock Text="No Liability" FontWeight="SemiBold" FontSize="15" />
          <TextBlock TextWrapping="Wrap"
                     Text="As far as the law allows, the software comes as is, without any warranty or condition, and the licensor will not be liable to you for any damages arising out of these terms or the use or nature of the software, under any kind of legal claim." />

          <TextBlock Text="Definitions" FontWeight="SemiBold" FontSize="15" />
          <TextBlock TextWrapping="Wrap"
                     Text="The licensor is the individual or entity offering these terms, and the software is the software the licensor makes available under these terms. You refers to the individual or entity agreeing to these terms. Your company is any legal entity, sole proprietorship, or other kind of organization that you work for, plus all organizations that have control over, are under the control of, or are under common control with that organization. Control means ownership of substantially all the assets of an entity, or the power to direct its management and policies by vote, contract, or otherwise. Control can be direct or indirect. Your licenses are all the licenses granted to you for the software under these terms. Use means anything you do with the software requiring one of your licenses." />

          <TextBlock Text="© PolyForm Project Inc."
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                     Margin="0,8,0,0" />
        </StackPanel>
      </ScrollViewer>

      <!-- ── About ─────────────────────────────────────────────────────── -->
      <StackPanel Margin="12" Spacing="8" IsVisible="{Binding IsAboutPage}">
        <TextBlock Text="AI Copyright Reproducibility" FontWeight="Bold" FontSize="18" />
        <TextBlock Text="{Binding AppVersion, StringFormat='Version {0}'}" FontSize="13"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        <TextBlock TextWrapping="Wrap"
                   Text="A tool for running and analysing AI copyright reproducibility experiments." />
        <HyperlinkButton NavigateUri="https://ai-copyright-reproducibility.tauheed-elahee.com/"
                         Content="https://ai-copyright-reproducibility.tauheed-elahee.com/"
                         Padding="0" />
      </StackPanel>

    </Grid>
  </ui:FANavigationView>

</Window>
